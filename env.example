# .env.example — скопируй в .env.local для локальной разработки
# В Vercel добавляй через Dashboard → Project → Settings → Environment Variables

# === Anthropic Claude (для /api/* если решишь перенести ИИ на сервер) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=1234567890:AAH...

# === Supabase ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJh...   # service_role, НЕ anon key!

# === Фронтенд (VITE_ prefix — доступны в браузере!) ===
VITE_INVOICE_ENDPOINT=https://your-app.vercel.app/api/create-invoice
